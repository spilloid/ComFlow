{
  "name": "comflow",
  "private": true,
  "version": "2.3.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace @comflow/frontend",
    "dev:backend": "npm run dev --workspace @comflow/backend",
    "dev": "concurrently -n frontend,backend -c blue,green \"npm:dev:frontend\" \"npm:dev:backend\"",
    "build": "npm run build --workspace @comflow/backend && npm run build --workspace @comflow/frontend",
    "lint": "npm run lint --workspaces --if-present",
    "seed": "npm run seed --workspace @comflow/backend"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.6.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0"
  }
}
